     D rc              S             10I 0 inz
     D msg             DS                  likeds(msg_t ) inz
      * - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
      /FREE

         rc = f_crtIfsDir(i_path: *omit: *omit: msg);
         rc = f_crtIfsDir(i_path: cIFS_MKDIR_RECURSION: *omit: msg);

         return;

